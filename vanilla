// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: db:create
// ─────────────────────────────────────────────────────────────────────────────
function cmd_db_create(array $args): void {
    $dbName = $_ENV['DB_DATABASE'] ?? '';
    if ($dbName === '') {
        error('DB_DATABASE is not set in .env');
        return;
    }

    $driver   = $_ENV['DB_DRIVER']   ?? 'mysql';
    $host     = $_ENV['DB_HOST']     ?? '127.0.0.1';
    $port     = $_ENV['DB_PORT']     ?? '3306';
    $username = $_ENV['DB_USERNAME'] ?? 'root';
    $password = $_ENV['DB_PASSWORD'] ?? '';

    try {
        $dsn = "{$driver}:host={$host};port={$port}";
        $pdo = new PDO($dsn, $username, $password, [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
        ]);
        $pdo->exec("CREATE DATABASE IF NOT EXISTS `{$dbName}` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
        success("Database '{$dbName}' created successfully.");
    } catch (PDOException $e) {
        error("Failed to create database: " . $e->getMessage());
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Migration Helpers
// ─────────────────────────────────────────────────────────────────────────────
function ensureMigrationsTable(PDO $db): void {
    $db->exec("CREATE TABLE IF NOT EXISTS `migrations` (
        `id` INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
        `migration` VARCHAR(255) NOT NULL,
        `batch` INT NOT NULL,
        `executed_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4");
}

function getExecutedMigrations(PDO $db): array {
    $stmt = $db->query("SELECT `migration` FROM `migrations` ORDER BY `id`");
    return $stmt->fetchAll(PDO::FETCH_COLUMN);
}

function getMigrationFiles(): array {
    $path = BASE_PATH . '/database/migrations';
    if (!is_dir($path)) {
        return [];
    }
    $files = glob($path . '/*.sql');
    sort($files);
    return $files;
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: migrate
// ─────────────────────────────────────────────────────────────────────────────
function cmd_migrate(array $args): void {
    try {
        $db = getDb();
    } catch (PDOException $e) {
        error("Database connection failed: " . $e->getMessage());
        line("Run " . color("php vanilla db:create", 'cyan') . " first.");
        return;
    }

    ensureMigrationsTable($db);
    $executed = getExecutedMigrations($db);
    $files = getMigrationFiles();
    $batch = 0;

    // Get current max batch
    $stmt = $db->query("SELECT COALESCE(MAX(`batch`), 0) FROM `migrations`");
    $batch = (int) $stmt->fetchColumn() + 1;

    $ran = 0;
    foreach ($files as $file) {
        $name = basename($file);
        if (in_array($name, $executed, true)) {
            continue;
        }

        $sql = file_get_contents($file);
        if (empty(trim($sql)) || trim($sql) === '--') {
            warn("Skipping empty migration: {$name}");
            continue;
        }

        info("Migrating: " . color($name, 'cyan'));
        try {
            // Strip comment-only lines, then split on semicolons
            $lines = explode("\n", $sql);
            $cleanLines = array_filter($lines, fn($l) => !str_starts_with(trim($l), '--'));
            $cleanSql = implode("\n", $cleanLines);
            $statements = array_filter(
                array_map('trim', explode(';', $cleanSql)),
                fn($s) => $s !== ''
            );
            foreach ($statements as $statement) {
                $db->exec($statement);
            }
            $stmt = $db->prepare("INSERT INTO `migrations` (`migration`, `batch`) VALUES (?, ?)");
            $stmt->execute([$name, $batch]);
            success("Migrated:  " . color($name, 'cyan'));
            $ran++;
        } catch (PDOException $e) {
            error("Failed to migrate {$name}: " . $e->getMessage());
            return;
        }
    }

    if ($ran === 0) {
        info("Nothing to migrate. All migrations are up to date.");
    } else {
        line();
        success("Ran {$ran} migration(s).");
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: migrate:fresh
// ─────────────────────────────────────────────────────────────────────────────
function cmd_migrate_fresh(array $args): void {
    try {
        $db = getDb();
    } catch (PDOException $e) {
        error("Database connection failed: " . $e->getMessage());
        return;
    }

    info("Dropping all tables...");

    // Disable FK checks
    $db->exec("SET FOREIGN_KEY_CHECKS = 0");
    $stmt = $db->query("SHOW TABLES");
    $tables = $stmt->fetchAll(PDO::FETCH_COLUMN);
    foreach ($tables as $table) {
        $db->exec("DROP TABLE IF EXISTS `{$table}`");
        line("  Dropped: {$table}");
    }
    $db->exec("SET FOREIGN_KEY_CHECKS = 1");
    success("All tables dropped.");
    line();

    // Re-run migrations
    cmd_migrate($args);
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: migrate:status
// ─────────────────────────────────────────────────────────────────────────────
function cmd_migrate_status(array $args): void {
    try {
        $db = getDb();
    } catch (PDOException $e) {
        error("Database connection failed: " . $e->getMessage());
        return;
    }

    ensureMigrationsTable($db);
    $executed = getExecutedMigrations($db);
    $files = getMigrationFiles();

    if (empty($files)) {
        info("No migration files found.");
        return;
    }

    echo "\n";
    $header = sprintf("  %-6s %-50s %s", "Ran?", "Migration", "Status");
    echo color($header, 'gray') . "\n";
    echo "  " . str_repeat('─', 70) . "\n";

    foreach ($files as $file) {
        $name = basename($file);
        $ran = in_array($name, $executed, true);
        $status = $ran ? color('Yes', 'green') : color('No ', 'yellow');
        $label = $ran ? color('Migrated', 'green') : color('Pending ', 'yellow');
        printf("  %-15s %-50s %s\n", $status, $name, $label);
    }
    echo "\n";
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: db:seed
// ─────────────────────────────────────────────────────────────────────────────
function cmd_db_seed(array $args): void {
    $class = getOption($args, 'class', '');

    $seedsPath = BASE_PATH . '/database/seeds';
    if (!is_dir($seedsPath)) {
        error("Seeds directory not found.");
        return;
    }

    // Seeder dependency map (prerequisites run first automatically)
    $seederDependencies = [
        'OrderSeeder' => ['MenuSeeder'],
        'MenuSeeder'  => [],
        'AdminSeeder' => [],
    ];

    if ($class !== '') {
        // Run specific seeder + its dependencies
        $queue = [$class];
        if (isset($seederDependencies[$class])) {
            $queue = array_merge($seederDependencies[$class], [$class]);
        }
        foreach (array_unique($queue) as $name) {
            $file = $seedsPath . '/' . $name . '.php';
            if (!file_exists($file)) {
                error("Seeder file not found: {$name}.php");
                return;
            }
            info("Seeding: " . color($name, 'cyan'));
            runSeederFile($file);
            success("Seeded:  " . color($name, 'cyan'));
        }
    } else {
        // Run all seeders in dependency-safe order
        $order = ['AdminSeeder', 'MenuSeeder', 'OrderSeeder'];
        foreach ($order as $name) {
            $file = $seedsPath . '/' . $name . '.php';
            if (!file_exists($file)) {
                warn("Seeder file not found, skipping: {$name}.php");
                continue;
            }
            info("Seeding: " . color($name, 'cyan'));
            runSeederFile($file);
            success("Seeded:  " . color($name, 'cyan'));
        }
    }
    line();
    success("Database seeding completed.");
}

function runSeederFile(string $file): void {
    // Seeders are self-bootstrapping scripts, but when run from vanilla CLI
    // the environment is already loaded. We need to handle the define() conflicts.
    // Use a subprocess to run the seeder in isolation.
    $output = [];
    $code = 0;
    exec('php ' . escapeshellarg($file) . ' 2>&1', $output, $code);
    foreach ($output as $l) {
        line("  " . $l);
    }
    if ($code !== 0) {
        error("Seeder exited with code {$code}");
    }
}

