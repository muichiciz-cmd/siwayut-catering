// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: key:generate
// ─────────────────────────────────────────────────────────────────────────────
function cmd_key_generate(array $args): void {
    $key = 'base64:' . base64_encode(random_bytes(32));

    // Try to update .env
    $envPath = BASE_PATH . '/.env';
    if (file_exists($envPath)) {
        $content = file_get_contents($envPath);
        if (preg_match('/^APP_KEY=/m', $content)) {
            $content = preg_replace('/^APP_KEY=.*/m', "APP_KEY=\"{$key}\"", $content);
        } else {
            $content .= "\nAPP_KEY=\"{$key}\"\n";
        }
        file_put_contents($envPath, $content);
    }

    success("Application key generated: " . color($key, 'cyan'));
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: cache:clear
// ─────────────────────────────────────────────────────────────────────────────
function cmd_cache_clear(array $args): void {
    $cleared = 0;

    // Clear logs
    $logPath = BASE_PATH . '/storage/logs';
    if (is_dir($logPath)) {
        $files = glob($logPath . '/*.log');
        foreach ($files as $file) {
            unlink($file);
            $cleared++;
        }
        info("Cleared " . count($files) . " log file(s).");
    }

    // Clear cache files
    $cachePath = BASE_PATH . '/storage/cache';
    if (is_dir($cachePath)) {
        $files = glob($cachePath . '/*');
        foreach ($files as $file) {
            if (basename($file) !== '.gitkeep') {
                unlink($file);
                $cleared++;
            }
        }
    }

    // Clear OPcache if available
    if (function_exists('opcache_reset')) {
        opcache_reset();
        info("OPcache cleared.");
    }

    success("Cache cleared. {$cleared} file(s) removed.");
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMAND: tinker
// ─────────────────────────────────────────────────────────────────────────────
function cmd_tinker(array $args): void {
    showBanner();
    info("Interactive shell. Type " . color("exit", 'cyan') . " to quit.");
    line();

    // Set up the environment
    $container = new \App\Core\Container();
    require BASE_PATH . '/config/bindings.php';

    while (true) {
        $input = readline(color(">>> ", 'green'));
        if ($input === false || trim($input) === 'exit' || trim($input) === 'quit') {
            line();
            info("Goodbye!");
            break;
        }
        if (trim($input) === '') {
            continue;
        }
        readline_add_history($input);

        try {
            // If it starts with $, it's likely an expression
            $code = trim($input);
            if (!str_ends_with($code, ';')) {
                $code .= ';';
            }
            // Wrap in try/catch and output
            $result = eval("return ({$code});") ?? eval($code);
            if ($result !== null) {
                echo color("=> ", 'gray');
                if (is_array($result) || is_object($result)) {
                    print_r($result);
                } else {
                    var_export($result);
                    echo "\n";
                }
            }
        } catch (\Throwable $e) {
            error($e->getMessage());
        }
    }
}

