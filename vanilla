// ─────────────────────────────────────────────────────────────────────────────
function cmd_routes(array $args): void {
    // Parse routes from config/routes.php source
    $source = file_get_contents(BASE_PATH . '/config/routes.php');

    echo "\n";
    echo color("  Registered Routes", 'bold') . "\n";
    echo "  " . str_repeat('─', 72) . "\n";
    printf("  %-8s %-28s %-30s %s\n",
        color('Method', 'gray'),
        color('URI', 'gray'),
        color('Handler', 'gray'),
        color('Middleware', 'gray')
    );
    echo "  " . str_repeat('─', 72) . "\n";

    // Quick parse — read route definitions from config/routes.php
    // We'll actually instantiate the router to get the real route list
    $container = new \App\Core\Container();

    // Bind minimal dependencies (no DB needed)
    $container->bind(\App\Controllers\WelcomeController::class, fn($c) => new \App\Controllers\WelcomeController());

    $router = new \App\Core\Router($container);
    $router->addMiddleware('auth', \App\Middleware\AuthMiddleware::class);
    $router->addMiddleware('role', \App\Middleware\RoleMiddleware::class);
    $router->addMiddleware('csrf', \App\Middleware\CsrfMiddleware::class);

    $registerRoutes = require BASE_PATH . '/config/routes.php';
    $registerRoutes($router);

    // Access private routes via reflection
    $ref = new ReflectionClass($router);
    $prop = $ref->getProperty('routes');
    $routes = $prop->getValue($router);

    foreach ($routes as $route) {
        $method = $route['method'];
        $path = $route['path'];
        $mw = !empty($route['middleware']) ? implode(', ', $route['middleware']) : color('—', 'gray');

        if (is_array($route['handler'])) {
            $class = basename(str_replace('\\', '/', $route['handler'][0]));
            $handler = $class . '@' . $route['handler'][1];
        } else {
            $handler = 'Closure';
        }

        $methodColor = match($method) {
            'GET'    => 'green',
            'POST'   => 'blue',
            'PUT'    => 'yellow',
            'PATCH'  => 'magenta',
            'DELETE' => 'red',
            default  => 'white',
        };

        printf("  %-17s %-28s %-30s %s\n",
            color(str_pad($method, 7), $methodColor),
            $path,
            $handler,
            $mw
        );
    }
    echo "\n";
    line(color((string)count($routes), 'bold') . " route(s) registered.");
    echo "\n";
}

