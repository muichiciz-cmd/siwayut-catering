# File: .env.example
APP_NAME="Siwayut"
APP_KEY=
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=siwayut_catering
DB_USERNAME=root
DB_PASSWORD=

# AI description generation — OpenAI-compatible API
# Set AI_API_URL to any OpenAI-compatible endpoint:
#   Google Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
#   FreeTheAi:     https://api.freetheai.xyz/v1
#   Free.ai:       https://api.free.ai/v1
#   Ollama lokal:  http://localhost:11434/v1
AI_API_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
AI_API_KEY="YOUR-GOOGLE-AI-API-KEY"
AI_MODEL="gemini-3.1-flash-lite"

# Cloudflare Turnstile CAPTCHA
TURNSTILE_ENABLED=true

# Managed widget keys
TURNSTILE_SITE_KEY_MANAGED=
TURNSTILE_SECRET_KEY_MANAGED=